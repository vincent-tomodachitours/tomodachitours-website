{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "build"
            }
        }
    ],
    "redirects": [
        {
            "source": "/(.*)",
            "destination": "https://tomodachitours.com/$1",
            "permanent": true,
            "has": [
                {
                    "type": "host",
                    "value": "tomodachitours-website.vercel.app"
                }
            ]
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/favicon.ico"
        },
        {
            "src": "/manifest.json",
            "dest": "/manifest.json"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}